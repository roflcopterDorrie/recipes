<?php

use Drupal\node\Entity\Node;

/**
 * Implements hook_theme().
 */
function recipes_theme($existing, $type, $theme, $path) {
  return [
    'recipe_preview' => [
      'variables' => [
        'recipe' => NULL,
      ],
      'template' => 'recipe-preview',
    ],
    'recipes_ingredient_summary' => [
      'template' => 'recipes--ingredient--summary',
      'variables' => [
        'node' => NULL,
        'content' => NULL,
      ],
      'path' => \Drupal::service('extension.list.module')->getPath('recipes') . '/templates',
    ],
  ];
}


function recipes_preprocess_recipes_ingredient_summary(&$variables) {
  /** @var \Drupal\node\Entity\Node $node */
  $node = $variables['node'];  

  $variables['amount'] = $node->get('field_recipes_ingredient_amount')->value;

  $name = $node->get('field_recipes_ingredient')->referencedEntities();
  $variables['name'] = reset($name)->get('name')->value;
  $variables['extra'] = $node->get('field_recipes_ingredient_extra')->value;
}